{
  "info": {
    "name": "RestroMind API",
    "description": "Complete API collection for RestroMind monolithic application. Base URL: http://localhost:8080\n\nFlow:\n1. Register as ADMIN → POST /auth/register\n2. Login → POST /auth/login (token auto-saved)\n3. Onboarding steps 1→2→3 to create a restaurant\n4. Create categories and dishes under Menu Management\n5. Discovery and Menu public APIs need no token",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (ADMIN)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@restromind.com\",\n  \"password\": \"password123\",\n  \"fullName\": \"Admin User\",\n  \"role\": \"ADMIN\"\n}"
            }
          }
        },
        {
          "name": "Register (USER)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@restromind.com\",\n  \"password\": \"password123\",\n  \"fullName\": \"Regular User\",\n  \"role\": \"USER\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('token', json.accessToken);",
                  "pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@restromind.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Change Password (Settings)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/password", "host": ["{{baseUrl}}"], "path": ["auth", "password"] },
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"password123\",\n  \"newPassword\": \"newpassword456\"\n}" }
          }
        },
        {
          "name": "Update Account Info (Settings)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/account", "host": ["{{baseUrl}}"], "path": ["auth", "account"] },
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Updated Name\",\n  \"email\": \"newemail@test.com\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Restaurant — Onboarding (ADMIN)",
      "description": "Must be logged in as ADMIN. Run steps 1 → 2 → 3 in order.",
      "item": [
        {
          "name": "Step 1 — Name & Logo",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/restaurants/onboarding/step1", "host": ["{{baseUrl}}"], "path": ["restaurants", "onboarding", "step1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pizza Palace\",\n  \"logoUrl\": \"https://example.com/logo.png\"\n}"
            }
          }
        },
        {
          "name": "Step 2 — Cuisine & Description",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/restaurants/onboarding/step2", "host": ["{{baseUrl}}"], "path": ["restaurants", "onboarding", "step2"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cuisineType\": \"ITALIAN\",\n  \"description\": \"Authentic Italian pizza and pasta since 1990.\"\n}"
            }
          }
        },
        {
          "name": "Step 3 — Address, Hours & Location",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/restaurants/onboarding/step3", "host": ["{{baseUrl}}"], "path": ["restaurants", "onboarding", "step3"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"addressLine1\": \"123 Main Street\",\n  \"addressLine2\": \"Ground Floor\",\n  \"city\": \"Mumbai\",\n  \"state\": \"Maharashtra\",\n  \"postalCode\": \"400001\",\n  \"country\": \"India\",\n  \"phone\": \"9876543210\",\n  \"latitude\": 19.0760,\n  \"longitude\": 72.8777,\n  \"estimatedDeliveryTime\": 30,\n  \"operatingHours\": [\n    { \"dayOfWeek\": \"MONDAY\",    \"openTime\": \"09:00\", \"closeTime\": \"22:00\" },\n    { \"dayOfWeek\": \"TUESDAY\",   \"openTime\": \"09:00\", \"closeTime\": \"22:00\" },\n    { \"dayOfWeek\": \"WEDNESDAY\", \"openTime\": \"09:00\", \"closeTime\": \"22:00\" },\n    { \"dayOfWeek\": \"THURSDAY\",  \"openTime\": \"09:00\", \"closeTime\": \"22:00\" },\n    { \"dayOfWeek\": \"FRIDAY\",    \"openTime\": \"09:00\", \"closeTime\": \"23:00\" },\n    { \"dayOfWeek\": \"SATURDAY\",  \"openTime\": \"10:00\", \"closeTime\": \"23:00\" },\n    { \"dayOfWeek\": \"SUNDAY\",    \"openTime\": \"10:00\", \"closeTime\": \"21:00\" }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get Onboarding Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/restaurants/onboarding/status", "host": ["{{baseUrl}}"], "path": ["restaurants", "onboarding", "status"] }
          }
        }
      ]
    },
    {
      "name": "Restaurant — Profile (ADMIN)",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/restaurants/me", "host": ["{{baseUrl}}"], "path": ["restaurants", "me"] }
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/restaurants/me", "host": ["{{baseUrl}}"], "path": ["restaurants", "me"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pizza Palace Updated\",\n  \"logoUrl\": \"https://example.com/new-logo.png\",\n  \"description\": \"Updated description.\",\n  \"cuisineType\": \"ITALIAN\",\n  \"addressLine1\": \"456 New Street\",\n  \"city\": \"Mumbai\",\n  \"state\": \"Maharashtra\",\n  \"postalCode\": \"400002\",\n  \"country\": \"India\",\n  \"phone\": \"9876543210\",\n  \"latitude\": 19.0760,\n  \"longitude\": 72.8777,\n  \"estimatedDeliveryTime\": 25,\n  \"operatingHours\": [\n    { \"dayOfWeek\": \"MONDAY\", \"openTime\": \"10:00\", \"closeTime\": \"22:00\" },\n    { \"dayOfWeek\": \"FRIDAY\", \"openTime\": \"10:00\", \"closeTime\": \"23:00\" }\n  ]\n}"
            }
          }
        },
        {
          "name": "Set Status → OPEN",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/restaurants/me/status", "host": ["{{baseUrl}}"], "path": ["restaurants", "me", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"OPEN\"\n}" }
          }
        },
        {
          "name": "Set Status → CLOSED",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/restaurants/me/status", "host": ["{{baseUrl}}"], "path": ["restaurants", "me", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"CLOSED\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Restaurant — Discovery (Public)",
      "description": "No authentication required.",
      "item": [
        {
          "name": "List All Available Restaurants",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/restaurants", "host": ["{{baseUrl}}"], "path": ["restaurants"] }
          }
        },
        {
          "name": "List — Filter by Cuisine",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/restaurants?cuisineType=ITALIAN",
              "host": ["{{baseUrl}}"], "path": ["restaurants"],
              "query": [{ "key": "cuisineType", "value": "ITALIAN" }]
            }
          }
        },
        {
          "name": "List — Sort by Rating",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/restaurants?sortBy=rating",
              "host": ["{{baseUrl}}"], "path": ["restaurants"],
              "query": [{ "key": "sortBy", "value": "rating" }]
            }
          }
        },
        {
          "name": "List — Sort by Delivery Time",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/restaurants?sortBy=deliveryTime",
              "host": ["{{baseUrl}}"], "path": ["restaurants"],
              "query": [{ "key": "sortBy", "value": "deliveryTime" }]
            }
          }
        },
        {
          "name": "List — Sort by Distance",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/restaurants?sortBy=distance&latitude=19.0760&longitude=72.8777",
              "host": ["{{baseUrl}}"], "path": ["restaurants"],
              "query": [
                { "key": "sortBy", "value": "distance" },
                { "key": "latitude", "value": "19.0760" },
                { "key": "longitude", "value": "72.8777" }
              ]
            }
          }
        },
        {
          "name": "List — Paginated (page 0, size 5)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/restaurants?page=0&size=5",
              "host": ["{{baseUrl}}"], "path": ["restaurants"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "Search by Name",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/restaurants/search?query=pizza",
              "host": ["{{baseUrl}}"], "path": ["restaurants", "search"],
              "query": [{ "key": "query", "value": "pizza" }]
            }
          }
        },
        {
          "name": "Get Restaurant by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/restaurants/1", "host": ["{{baseUrl}}"], "path": ["restaurants", "1"] }
          }
        }
      ]
    },
    {
      "name": "Menu — Public",
      "description": "No authentication required.",
      "item": [
        {
          "name": "Get Restaurant Menu",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/menu/restaurants/1", "host": ["{{baseUrl}}"], "path": ["menu", "restaurants", "1"] }
          }
        },
        {
          "name": "Get Dish by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/menu/dishes/1", "host": ["{{baseUrl}}"], "path": ["menu", "dishes", "1"] }
          }
        }
      ]
    },
    {
      "name": "Menu — Management (ADMIN)",
      "description": "Requires ADMIN JWT. Replace restaurantId/categoryId/dishId as needed.",
      "item": [
        {
          "name": "Get Full Menu (Admin View, incl. unavailable)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/menu/restaurants/1/admin", "host": ["{{baseUrl}}"], "path": ["menu", "restaurants", "1", "admin"] }
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/menu/restaurants/1/categories", "host": ["{{baseUrl}}"], "path": ["menu", "restaurants", "1", "categories"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Starters\",\n  \"sortIndex\": 0\n}" }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/menu/restaurants/1/categories/1", "host": ["{{baseUrl}}"], "path": ["menu", "restaurants", "1", "categories", "1"] },
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Appetizers\",\n  \"sortIndex\": 0\n}" }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/menu/restaurants/1/categories/1", "host": ["{{baseUrl}}"], "path": ["menu", "restaurants", "1", "categories", "1"] }
          }
        },
        {
          "name": "Add Dish to Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/menu/restaurants/1/categories/1/dishes", "host": ["{{baseUrl}}"], "path": ["menu", "restaurants", "1", "categories", "1", "dishes"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Margherita Pizza\",\n  \"description\": \"Classic tomato and mozzarella\",\n  \"price\": 299.00,\n  \"imageUrl\": \"https://example.com/margherita.jpg\",\n  \"allergens\": \"Gluten, Dairy\"\n}"
            }
          }
        },
        {
          "name": "Update Dish",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/menu/restaurants/1/dishes/1", "host": ["{{baseUrl}}"], "path": ["menu", "restaurants", "1", "dishes", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Margherita Pizza (Large)\",\n  \"description\": \"Classic tomato and mozzarella - large size\",\n  \"price\": 399.00,\n  \"imageUrl\": \"https://example.com/margherita.jpg\",\n  \"allergens\": \"Gluten, Dairy\"\n}"
            }
          }
        },
        {
          "name": "Toggle Dish Availability — Unavailable",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/menu/restaurants/1/dishes/1/availability", "host": ["{{baseUrl}}"], "path": ["menu", "restaurants", "1", "dishes", "1", "availability"] },
            "body": { "mode": "raw", "raw": "{\n  \"available\": false\n}" }
          }
        },
        {
          "name": "Toggle Dish Availability — Available",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/menu/restaurants/1/dishes/1/availability", "host": ["{{baseUrl}}"], "path": ["menu", "restaurants", "1", "dishes", "1", "availability"] },
            "body": { "mode": "raw", "raw": "{\n  \"available\": true\n}" }
          }
        },
        {
          "name": "Delete Dish (Soft Delete)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/menu/restaurants/1/dishes/1", "host": ["{{baseUrl}}"], "path": ["menu", "restaurants", "1", "dishes", "1"] }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "description": "Requires JWT. Users place orders; admins manage status.",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/orders", "host": ["{{baseUrl}}"], "path": ["orders"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurantId\": 1,\n  \"items\": [\n    { \"dishId\": 1, \"quantity\": 2 }\n  ],\n  \"deliveryAddress\": \"456 Customer St, Mumbai\",\n  \"specialInstructions\": \"Extra spicy\"\n}"
            }
          }
        },
        {
          "name": "My Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/orders/me", "host": ["{{baseUrl}}"], "path": ["orders", "me"] }
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/orders/1", "host": ["{{baseUrl}}"], "path": ["orders", "1"] }
          }
        },
        {
          "name": "Restaurant Orders (Admin) — All",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/orders/restaurant/1?page=0&size=20", "host": ["{{baseUrl}}"], "path": ["orders", "restaurant", "1"], "query": [{"key":"page","value":"0"},{"key":"size","value":"20"}] }
          }
        },
        {
          "name": "Restaurant Orders (Admin) — Filter by Status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/orders/restaurant/1?status=PENDING&page=0&size=20", "host": ["{{baseUrl}}"], "path": ["orders", "restaurant", "1"], "query": [{"key":"status","value":"PENDING"},{"key":"page","value":"0"},{"key":"size","value":"20"}] }
          }
        },
        {
          "name": "Order Print View",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/orders/1/print", "host": ["{{baseUrl}}"], "path": ["orders", "1", "print"] }
          }
        },
        {
          "name": "Confirm Order (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/orders/1/status", "host": ["{{baseUrl}}"], "path": ["orders", "1", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"CONFIRMED\"\n}" }
          }
        },
        {
          "name": "Advance to PREPARING (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/orders/1/status", "host": ["{{baseUrl}}"], "path": ["orders", "1", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"PREPARING\"\n}" }
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/orders/1/status", "host": ["{{baseUrl}}"], "path": ["orders", "1", "status"] },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"CANCELLED\",\n  \"cancellationReason\": \"Changed my mind\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "description": "Requires JWT. Users manage preferences and view history. /send is called internally.",
      "item": [
        {
          "name": "Get My Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/notifications/me?page=0&size=20",
              "host": ["{{baseUrl}}"], "path": ["notifications", "me"],
              "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "20" }]
            }
          }
        },
        {
          "name": "Get My Preferences",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/notifications/preferences", "host": ["{{baseUrl}}"], "path": ["notifications", "preferences"] }
          }
        },
        {
          "name": "Update Preferences",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
